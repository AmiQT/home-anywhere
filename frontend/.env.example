# Public site URL (used in metadata, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 measurement ID (optional — leave blank to disable)
NEXT_PUBLIC_GA_ID=

# Backend API base URL — used by next.config.mjs to proxy /api/* requests
BACKEND_URL=http://127.0.0.1:8000

# Basic auth for /admin and /api/admin/* (middleware.ts)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
