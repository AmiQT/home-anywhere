# Optional overrides for `docker compose up`.
#
# Copy this to `.env` IN THIS ROOT FOLDER (next to docker-compose.yml) to
# change the defaults. Everything here is optional — the stack boots fine
# with none of it set (demo mode, default admin login).
#
#   cp .env.docker.example .env
#
# NOTE: this file is for the Docker stack only. The per-app
# backend/.env and frontend/.env are NOT used when running via Docker.

# --- Admin dashboard login ---
# Used for both the /admin UI and the /api/admin/* API. Change before
# putting this in front of a real business.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- Stripe (deposit payments) ---
# Leave blank to run in demo mode (bookings confirm instantly, no real charge).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Analytics 4 (optional) ---
NEXT_PUBLIC_GA_ID=
