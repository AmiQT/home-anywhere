APP_NAME="Home Anywhere"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database ---
# Default is SQLite for zero-config development.
# For production, switch to mysql or pgsql and fill in DB_* values below.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=home_anywhere
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# --- Mail (booking confirmation emails) ---
# Use "log" in development to print emails to laravel.log.
# In production, set MAIL_MAILER=smtp and fill in real credentials.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@home-anywhere.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- Stripe (deposit payments) ---
# Leave blank to run in demo mode: bookings will skip Stripe and go straight to /success.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Calendar (auto-sync bookings) ---
# Leave blank to skip calendar event creation.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_CALENDAR_ID=

# --- Admin API auth ---
# Must match the values in frontend/.env. The backend rejects /api/admin/*
# requests whose Basic credentials do not match these.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- Initial admin user seeded by `php artisan db:seed` ---
# Optional — leave blank to use safe local-only defaults.
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
